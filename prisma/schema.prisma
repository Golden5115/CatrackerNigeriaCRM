generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  password          String
  fullName          String?
  role              Role          @default(CSR)
  createdAt         DateTime      @default(now())
  accessibleModules String[]      @default([])
  address           String?
  guarantorAddress  String?
  guarantorName     String?
  guarantorPhone    String?
  phoneNumber       String?
  qualifications    String?
  status            AccountStatus @default(ACTIVE)
  updatedAt         DateTime      @default(now()) @updatedAt
  canDelete         Boolean       @default(false)
  canEdit           Boolean       @default(false)
  clientsAdded      Client[]      @relation("CreatedBy")
  installerJobs     Job[]         @relation("InstallerJobs")
  createdInvoices   Invoice[]
}

model Client {
  id          String    @id @default(uuid())
  fullName    String
  phoneNumber String    @unique
  notes       String?
  email       String?   @unique
  dob         DateTime?
  address     String?
  state       String?
  leadSource  String?
  createdById String?
  createdAt   DateTime  @default(now())
  createdBy   User?     @relation("CreatedBy", fields: [createdById], references: [id])
  vehicles    Vehicle[]
  invoices    Invoice[]
  @@index([phoneNumber])
  @@index([fullName])
  importBatchId String?  // 👈 NEW: Allows us to track and rollback imports
}

model Vehicle {
  id          String  @id @default(uuid())
  clientId    String
  name        String
  year        String?
  plateNumber String?
  color       String?
  jobs        Job[]
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([plateNumber])
}

model Device {
  id        String      @id @default(cuid())
  imei      String      @unique
  createdAt DateTime    @default(now())
  status    StockStatus @default(IN_STOCK)
  job       Job?
  @@index([imei])
  @@index([status])
}

model SimCard {
  id        String      @id @default(cuid())
  simNumber String      @unique
  network   String?
  status    StockStatus @default(IN_STOCK)
  createdAt DateTime    @default(now())
  job       Job?
  @@index([simNumber])
  @@index([status])
}

model Job {
  id                String    @id @default(uuid())
  vehicleId         String
  status            JobStatus @default(NEW_LEAD)
  lostReason        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  installDate       DateTime?
  installPhoto      String?
  odometer          Int?
  installerName     String?
  configurationDate DateTime?
  serverConfig      Boolean   @default(false)
  platformId        String?
  onboarded         Boolean   @default(false)
  paymentStatus     String    @default("UNPAID")
  amountPaid        Decimal   @default(0.00)
  paymentCollector  String?
  paymentDate       DateTime?
  deviceId          String?   @unique
  installerId       String?
  simCardId         String?   @unique
  jobType           JobType   @default(NEW_INSTALL)
  supportNotes      String?
  device            Device?   @relation(fields: [deviceId], references: [id])
  installer         User?     @relation("InstallerJobs", fields: [installerId], references: [id])
  simCard           SimCard?  @relation(fields: [simCardId], references: [id])
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  scheduledDate    DateTime?
  pendingReason    String?
  @@index([status])
}

enum Role {
  ADMIN
  CSR
  INSTALLER
  TECH_SUPPORT
  CEO
  MANAGER
  HR
  OPERATIONS
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum JobStatus {
  NEW_LEAD
  SCHEDULED
  IN_PROGRESS
  PENDING_QC
  CONFIGURED
  ACTIVE
  LEAD_LOST
}

enum StockStatus {
  IN_STOCK
  INSTALLED
  FAULTY
  RETIRED
}

enum JobType {
  NEW_INSTALL
  MAINTENANCE
  DEVICE_REPLACEMENT
  SIM_REPLACEMENT
  TRANSFER
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  
  // Optional link to Client Database
  clientId        String?
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  
  subject         String?
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  
  // Financials
  subtotal        Decimal       @default(0.00)
  discountType    String        @default("FIXED") // 'PERCENTAGE' or 'FIXED'
  discountValue   Decimal       @default(0.00)
  taxPercentage   Decimal       @default(0.00)
  total           Decimal       @default(0.00)
  
  status          String        @default("UNPAID") // UNPAID, PAID, CANCELLED
  notes           String?       // Terms & Conditions
  
  // Bank Details
  bankName        String?
  accountName     String?
  accountNumber   String?
  
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  client          Client?       @relation(fields: [clientId], references: [id])
  createdBy       User?         @relation(fields: [createdById], references: [id])
  items           InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0.00)
  total       Decimal  @default(0.00)
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}