// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---
enum Role {
  CEO
  MANAGER
  HR
  ADMIN
  OPERATIONS   // 👈 ADD THIS
  CSR
  INSTALLER
  TECH_SUPPORT
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum JobStatus {
  NEW_LEAD
  SCHEDULED
  IN_PROGRESS
  PENDING_QC
  CONFIGURED
  ACTIVE
  LEAD_LOST
}

enum StockStatus {
  IN_STOCK
  INSTALLED
  FAULTY
  RETIRED
}

enum JobType {
  NEW_INSTALL
  MAINTENANCE        
  DEVICE_REPLACEMENT 
  SIM_REPLACEMENT    
  TRANSFER           
}

// --- MODELS ---

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  password          String
  fullName          String?
  role              Role          @default(CSR)
  accessibleModules String[]      @default([]) 
  canEdit           Boolean       @default(false)
  canDelete         Boolean       @default(false)
  status            AccountStatus @default(ACTIVE) 
  
  // HR Profile Fields
  phoneNumber       String?
  address           String?
  qualifications    String?       
  guarantorName     String?
  guarantorPhone    String?
  guarantorAddress  String?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  
  clientsAdded      Client[]      @relation("CreatedBy")
  installerJobs     Job[]         @relation("InstallerJobs")
}

model Client {
  id          String    @id @default(uuid())
  fullName    String
  phoneNumber String    @unique
  notes       String?
  
  // --- LEAD INFO ---
  email       String?   @unique   
  dob         DateTime?
  address     String?
  state       String?
  leadSource  String?

  // --- RELATIONSHIPS ---
  vehicles    Vehicle[]
  
  createdById String?
  createdBy   User?     @relation("CreatedBy", fields: [createdById], references: [id])
  
  createdAt   DateTime  @default(now())
}

model Vehicle {
  id          String    @id @default(uuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  name        String    
  year        String?    
  plateNumber String?
  color       String?
  jobs        Job[]
}

model Device {
  id        String       @id @default(cuid())
  imei      String       @unique
  status    StockStatus  @default(IN_STOCK)
  
  job       Job?
  createdAt DateTime     @default(now())
}

model SimCard {
  id        String       @id @default(cuid())
  simNumber String       @unique
  network   String?      
  status    StockStatus  @default(IN_STOCK)

  job       Job?
  createdAt DateTime     @default(now())
}

model Job {
  id              String      @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  installerId     String?
  installer       User?       @relation("InstallerJobs", fields: [installerId], references: [id])
  
  status          JobStatus   @default(NEW_LEAD)
  
  deviceId        String?     @unique
  device          Device?     @relation(fields: [deviceId], references: [id])

  simCardId       String?     @unique
  simCard         SimCard?    @relation(fields: [simCardId], references: [id])

  lostReason      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  installDate     DateTime?
  installPhoto    String?
  odometer        Int?
  installerName   String?

  configurationDate DateTime? 
  serverConfig      Boolean   @default(false)
  platformId        String?
  
  onboarded         Boolean   @default(false)
  paymentStatus     String    @default("UNPAID")
  amountPaid        Decimal   @default(0.00) 
  paymentCollector  String?   

  jobType         JobType     @default(NEW_INSTALL)
  supportNotes    String?     @db.Text
}